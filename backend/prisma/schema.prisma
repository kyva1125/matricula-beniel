datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Business {
  id            String    @id @default(uuid())
  nombre        String
  direccion     String
  ruc           String?
  telefono      String?
  fechaCreacion DateTime  @default(now())
  users         User[]    @relation("BusinessUsers")
  students      Student[] @relation("BusinessStudents")
}

model User {
  id                 String    @id @default(uuid())
  businessId         String
  business           Business  @relation("BusinessUsers", fields: [businessId], references: [id], onDelete: Cascade)
  nombre             String
  correo             String    @unique
  password           String
  rol                String    // "administrador" | "apoderado" | "estudiante"
  activo             Boolean   @default(true)
  trialStartedAt     DateTime? // Para simulación de período de prueba de 7 días
  institucion        String?   // Nombre de la institución/colegio
  fechaCreacion      DateTime  @default(now())
  fechaActualizacion DateTime  @updatedAt
  alumnos            Student[] @relation("ApoderadoAlumnos")
  pagosRegistrados   Payment[] @relation("AdminRegistros")
}

model Student {
  id                 String    @id @default(uuid())
  businessId         String
  business           Business  @relation("BusinessStudents", fields: [businessId], references: [id], onDelete: Cascade)
  nombres            String
  apellidos          String
  dni                String    @unique
  grado              String
  seccion            String
  apoderadoId        String?
  apoderado          User?     @relation("ApoderadoAlumnos", fields: [apoderadoId], references: [id], onDelete: SetNull)
  pensiones          Pension[]
  fechaCreacion      DateTime  @default(now())
  fechaActualizacion DateTime  @updatedAt
}

model Pension {
  id                 String    @id @default(uuid())
  alumnoId           String
  alumno             Student   @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  mes                String    // "Matricula" | "Marzo" | "Abril" ...
  monto              Float
  fechaVencimiento   DateTime
  estado             String    // "PAGADO" | "PENDIENTE" | "VENCIDO"
  pagos              Payment[]
  fechaCreacion      DateTime  @default(now())
  fechaActualizacion DateTime  @updatedAt
}

model Payment {
  id                 String    @id @default(uuid())
  pensionId          String
  pension            Pension   @relation(fields: [pensionId], references: [id], onDelete: Cascade)
  montoPagado        Float
  metodoPago         String    // "YAPE" | "PLIN" | "TRANSFERENCIA" | "EFECTIVO"
  codigoOperacion    String    @unique
  fechaPago          DateTime  @default(now())
  comprobanteUrl     String?
  registradoPorId    String
  registradoPor      User      @relation("AdminRegistros", fields: [registradoPorId], references: [id])
  fechaCreacion      DateTime  @default(now())
}

